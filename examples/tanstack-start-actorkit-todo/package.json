{
  "name": "tanstack-start-actorkit-todo",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "pnpm build && wrangler dev -c .output/server/wrangler.json --port 3000 --inspector-port 0",
    "dev:e2e": "wrangler dev -c .output/server/wrangler.json --port 3002 --inspector-port 9230",
    "dev:e2e:build": "pnpm build",
    "build": "vite build",
    "preview": "pnpm build && wrangler dev -c .output/server/wrangler.json --port 3000 --inspector-port 0",
    "deploy": "pnpm build && wrangler deploy -c .output/server/wrangler.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint src server e2e playwright.config.ts nitro.config.ts exports.cloudflare.ts",
    "format": "prettier --check .",
    "check": "prettier --write . && eslint --fix"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "0.9.13",
    "@tanstack/react-router": "1.166.7",
    "@tanstack/react-router-devtools": "1.166.7",
    "@tanstack/react-router-ssr-query": "1.166.7",
    "@tanstack/react-start": "1.166.7",
    "@tanstack/router-plugin": "1.166.7",
    "@actor-kit/types": "workspace:*",
    "@actor-kit/worker": "workspace:*",
    "@actor-kit/react": "workspace:*",
    "@actor-kit/server": "workspace:*",
    "h3": "^2.0.1-rc.16",
    "lucide-react": "^0.577.0",
    "nitro": "3.0.260311-beta",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "xstate": "^5.28.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "0.5.5",
    "@tanstack/eslint-config": "0.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0",
    "wrangler": "catalog:"
  }
}
