{
  "name": "nextjs-actorkit-todo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:e2e": "NODE_OPTIONS=--preserve-symlinks ACTOR_KIT_HOST=127.0.0.1:8788 ACTOR_KIT_SECRET=actor-kit-dev-secret next dev --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "dev-api": "ACTOR_KIT_HOST=127.0.0.1:8788 ACTOR_KIT_SECRET=actor-kit-dev-secret wrangler dev --port 8788 --inspector-port 0",
    "deploy-api": "wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@actor-kit/types": "workspace:*",
    "@actor-kit/worker": "workspace:*",
    "@actor-kit/react": "workspace:*",
    "@actor-kit/server": "workspace:*",
    "cookie": "^0.6.0",
    "next": "14.2.13",
    "react": "^18",
    "react-dom": "^18",
    "xstate": "^5.18.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/cookie": "^0.6.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.13",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wrangler": "catalog:"
  }
}
